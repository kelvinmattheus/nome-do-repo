# Gerado automaticamente pelo Railway ao adicionar PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Troque por uma string longa e aleatória em produção (mín. 32 caracteres)
JWT_SECRET="troque-por-segredo-forte-aqui"

# Chave usada no endpoint /setup para criar o primeiro admin
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETUP_ADMIN_KEY="troque-esta-chave"

# Railway define PORT automaticamente — não precisa alterar
PORT=3000

# URL do frontend para controle de CORS (separar múltiplas origens por vírgula)
# Exemplo: https://meuapp.up.railway.app,https://meuapp.com
FRONTEND_URL="https://meuapp.up.railway.app"
