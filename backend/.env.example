# Gerado automaticamente pelo Railway ao adicionar PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Troque por uma string longa e aleatória em produção
JWT_SECRET="troque-por-segredo-forte-aqui"

# Chave usada no endpoint /setup para criar o primeiro admin
SETUP_ADMIN_KEY="troque-esta-chave"

# Railway define PORT automaticamente — não precisa alterar
PORT=3000
